generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum TransferStatus {
  LISTED
  OFFERED
  NEGOTIATING
  COMPLETED
  CANCELLED
}

enum MatchResult {
  HOME_WIN
  DRAW
  AWAY_WIN
  PENDING
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  username    String     @unique
  passwordHash String
  role        UserRole   @default(PLAYER)
  saveGames   SaveGame[]
  clubs       Club[]     @relation("ClubManager")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([username])
}

model SaveGame {
  id          String    @id @default(uuid())
  name        String
  season      Int       @default(1)
  currentWeek Int       @default(1)
  isActive    Boolean   @default(true)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubs       Club[]
  leagues     League[]
  matches     Match[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, isActive])
  @@index([season, currentWeek])
}

model League {
  id            String         @id @default(uuid())
  name          String
  country       String
  tier          Int
  season        Int
  saveGameId    String
  saveGame      SaveGame       @relation(fields: [saveGameId], references: [id], onDelete: Cascade)
  clubs         Club[]
  matches       Match[]
  tableRows     TableStanding[]
  transferMarket Transfer[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([saveGameId, name, season])
  @@index([country, tier])
}

model Club {
  id           String         @id @default(uuid())
  name         String
  shortName    String?
  country      String
  budget       Int            @default(0)
  wageBudget   Int            @default(0)
  reputation   Int            @default(50)
  foundedYear  Int?
  managerId    String?
  manager      User?          @relation("ClubManager", fields: [managerId], references: [id], onDelete: SetNull)
  saveGameId   String
  saveGame     SaveGame       @relation(fields: [saveGameId], references: [id], onDelete: Cascade)
  leagueId     String?
  league       League?        @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  players      Player[]
  homeMatches  Match[]        @relation("HomeClub")
  awayMatches  Match[]        @relation("AwayClub")
  tactics      Tactics[]
  scouts       Scout[]
  standings    TableStanding[]
  transfersIn  Transfer[]     @relation("TransferToClub")
  transfersOut Transfer[]     @relation("TransferFromClub")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([saveGameId, name])
  @@index([leagueId])
  @@index([managerId])
}

model Player {
  id          String    @id @default(uuid())
  clubId      String
  club        Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  nationality String
  age         Int
  preferredFoot String?
  position    String
  overall     Int       @default(50)
  potential   Int       @default(50)
  pac         Int       @default(50)
  sho         Int       @default(50)
  pas         Int       @default(50)
  dri         Int       @default(50)
  def         Int       @default(50)
  phy         Int       @default(50)
  morale      Int       @default(50)
  stamina     Int       @default(50)
  form        Int       @default(50)
  posX        Int       @default(0)
  posY        Int       @default(0)
  value       Int       @default(0)
  wage        Int       @default(0)
  isTransferListed Boolean @default(false)
  transfers   Transfer[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clubId, position])
  @@index([overall, potential])
  @@index([isTransferListed])
}

model Tactics {
  id             String   @id @default(uuid())
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name            String
  formation       String
  mentality       String
  pressing        Int      @default(50)
  lineHeight      Int      @default(50)
  width           Int      @default(50)
  passingStyle    String
  tempo           Int      @default(50)
  isDefault       Boolean  @default(false)
  playerPositions Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clubId, name])
  @@index([clubId, isDefault])
}

model Match {
  id           String      @id @default(uuid())
  saveGameId   String
  saveGame     SaveGame    @relation(fields: [saveGameId], references: [id], onDelete: Cascade)
  leagueId     String
  league       League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeClubId   String
  homeClub     Club        @relation("HomeClub", fields: [homeClubId], references: [id], onDelete: Cascade)
  awayClubId   String
  awayClub     Club        @relation("AwayClub", fields: [awayClubId], references: [id], onDelete: Cascade)
  matchDate    DateTime
  round        Int
  homeGoals    Int         @default(0)
  awayGoals    Int         @default(0)
  result       MatchResult @default(PENDING)
  events       Json
  played       Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([saveGameId, matchDate])
  @@index([leagueId, round])
  @@index([homeClubId])
  @@index([awayClubId])
}

model TableStanding {
  id          String   @id @default(uuid())
  leagueId    String
  league      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  clubId      String
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season      Int
  played      Int      @default(0)
  won         Int      @default(0)
  drawn       Int      @default(0)
  lost        Int      @default(0)
  goalsFor    Int      @default(0)
  goalsAgainst Int     @default(0)
  goalDiff    Int      @default(0)
  points      Int      @default(0)
  position    Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([leagueId, clubId, season])
  @@index([leagueId, season, position])
  @@index([clubId, season])
}

model Transfer {
  id            String         @id @default(uuid())
  playerId      String
  player        Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  fromClubId    String?
  fromClub      Club?          @relation("TransferFromClub", fields: [fromClubId], references: [id], onDelete: SetNull)
  toClubId      String?
  toClub        Club?          @relation("TransferToClub", fields: [toClubId], references: [id], onDelete: SetNull)
  leagueId      String?
  league        League?        @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  fee           Int            @default(0)
  wageOffered   Int            @default(0)
  status        TransferStatus @default(LISTED)
  listedAt      DateTime       @default(now())
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([playerId, status])
  @@index([fromClubId, status])
  @@index([toClubId, status])
  @@index([leagueId])
}

model Scout {
  id            String   @id @default(uuid())
  clubId         String
  club           Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name           String
  region         String
  judgingAbility Int      @default(50)
  judgingPotential Int    @default(50)
  knowledge      Int      @default(50)
  active         Boolean  @default(true)
  assignedSince  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clubId, active])
  @@index([region])
}
