generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PlayerRole {
  GOALKEEPER
  CENTER_BACK
  LEFT_BACK
  RIGHT_BACK
  SWEEPER
  LEFT_WING_BACK
  RIGHT_WING_BACK
  CENTRAL_MIDFIELDER
  DEFENSIVE_MIDFIELDER
  ATTACKING_MIDFIELDER
  LEFT_MIDFIELDER
  RIGHT_MIDFIELDER
  BOX_TO_BOX_MIDFIELDER
  ANCHOR
  LEFT_WINGER
  RIGHT_WINGER
  INVERTED_WINGER
  SECOND_STRIKER
  STRIKER
  TARGET_MAN
  FALSE_NINE
  PLAYMAKER
}

model League {
  id          String          @id @default(uuid())
  name        String
  country     String?
  season      Int             @default(1)
  clubs       Club[]
  matches     Match[]
  standings   TableStanding[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([name, season])
  @@index([season])
}

model Club {
  id          String          @id @default(uuid())
  name        String
  budget      Int             @default(0)
  reputation  Int             @default(50)
  leagueId    String?
  league      League?         @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  players     Player[]
  tactics     Tactics[]
  homeMatches Match[]         @relation("HomeTeam")
  awayMatches Match[]         @relation("AwayTeam")
  standings   TableStanding[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([name, leagueId])
  @@index([leagueId])
}

model Player {
  id          String      @id @default(uuid())
  clubId       String
  club         Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name         String
  age          Int

  pac          Int         @default(50)
  sho          Int         @default(50)
  pas          Int         @default(50)
  dri          Int         @default(50)
  def          Int         @default(50)
  phy          Int         @default(50)

  morale       Int         @default(50)
  stamina      Int         @default(50)
  form         Int         @default(50)
  potential    Int         @default(50)

  // Original Tactical Manager attributes (0-20 scale)
  played       Int         @default(0)
  scored       Int         @default(0)
  speed        Int         @default(10)
  control      Int         @default(10)
  tackling     Int         @default(10)
  passing      Int         @default(10)
  heading      Int         @default(5)
  shooting     Int         @default(5)
  marking      Int         @default(10)
  vision       Int         @default(10)
  caps         Int         @default(0)
  experience   Int         @default(5)
  fitness      Int         @default(10)
  freshness    Int         @default(15)
  influence    Int         @default(5)
  attitude     Int         @default(10)
  reliability  Int         @default(10)

  // StatsBomb-style event counters (accumulated per season)
  assists      Int         @default(0)
  shots        Int         @default(0)
  shotsOnTarget Int        @default(0)
  xG           Float       @default(0)
  xA           Float       @default(0)
  keyPasses    Int         @default(0)
  passesAttempted Int      @default(0)
  passesCompleted Int      @default(0)
  tackles_won  Int         @default(0)
  interceptions Int        @default(0)
  clearances   Int         @default(0)
  dribbleAttempts Int      @default(0)
  dribbleSuccessful Int    @default(0)
  aerialDuelsWon Int       @default(0)
  aerialDuelsLost Int      @default(0)
  pressures    Int         @default(0)
  foulsCommitted Int       @default(0)

  // Free positioning system on a 0-100 pitch grid.
  posX         Int         @default(50)
  posY         Int         @default(50)

  role         PlayerRole
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([clubId])
  @@index([role])
  @@index([clubId, posX, posY])
}

model Tactics {
  id            String      @id @default(uuid())
  clubId         String
  club           Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  formationName  String
  tempo          Int         @default(50)
  pressing       Int         @default(50)
  width          Int         @default(50)
  mentality      String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([clubId])
  @@unique([clubId, formationName])
}

model Match {
  id          String      @id @default(uuid())
  leagueId     String?
  league       League?     @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  homeTeamId   String
  homeTeam     Club        @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeamId   String
  awayTeam     Club        @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  scoreHome    Int         @default(0)
  scoreAway    Int         @default(0)
  events       Json
  matchDate    DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([leagueId, matchDate])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model TableStanding {
  id            String      @id @default(uuid())
  leagueId       String
  league         League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  clubId         String
  club           Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  played         Int         @default(0)
  won            Int         @default(0)
  drawn          Int         @default(0)
  lost           Int         @default(0)
  goalsFor       Int         @default(0)
  goalsAgainst   Int         @default(0)
  goalDiff       Int         @default(0)
  points         Int         @default(0)
  position       Int         @default(0)
  updatedAt      DateTime    @updatedAt

  @@unique([leagueId, clubId])
  @@index([leagueId, position])
  @@index([clubId])
}

// ────────────────────────────────────────────
// OFFLINE-FIRST: GameSave snapshot model
// ────────────────────────────────────────────

model GameSave {
  id        String   @id @default(uuid())
  clubId    String   @unique
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
  data      String   // JSON-serialized GameState snapshot

  @@index([clubId])
  @@index([clubId, version])
}
